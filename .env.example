# ===== ASAAS (assinaturas) =====
# Sandbox para testar; produção depois (token NÃO é o mesmo entre ambientes).
ASAAS_API_KEY=coloque_sua_chave_asaas_aqui
ASAAS_ENVIRONMENT=sandbox
# Opcional: se não definir, o sistema deduz pelo ASAAS_ENVIRONMENT.
#   sandbox  -> https://sandbox.asaas.com/api/v3
#   producao -> https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token secreto que VOCÊ define no painel da Asaas ao criar o webhook.
ASAAS_WEBHOOK_TOKEN=defina_um_token_secreto_para_o_webhook

# Liga a exigência de (re)aceite dos termos no login (0 = desligado).
EXIGIR_ACEITE_LOGIN=0
